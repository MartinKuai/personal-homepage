---
import { getCollection } from 'astro:content';

const entries = await getCollection('timeline');
const sortedEntries = entries
  .filter((entry) => !entry.data.draft && !entry.data.placeholder)
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="timeline" class="section-container">
  <div class="max-w-2xl">
    <p class="section-title">RECENT</p>
    <h2 class="section-heading">Recent</h2>
    <p class="mt-4 text-sm text-muted">
      这里保留少量和方向变化、项目推进、方法形成有关的记录。更完整的内容会逐步整理到 Notes 中。
    </p>
  </div>
  <div class="mt-16 max-w-2xl">
    <div class="space-y-0">
      {sortedEntries.map((entry, index) => (
        <a href={`/timeline/${entry.slug}/`} class="relative flex gap-6 pb-12 last:pb-0 group block">
          <div class="flex flex-col items-center">
            <div class="h-2 w-2 rounded-full bg-white/40 transition-colors group-hover:bg-white/70"></div>
            {index < sortedEntries.length - 1 && (
              <div class="mt-2 h-full w-px bg-white/10"></div>
            )}
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3">
              <h3 class="text-sm font-medium transition-colors group-hover:text-white">{entry.data.title}</h3>
              {entry.data.period && (
                <span class="text-xs text-muted">{entry.data.period}</span>
              )}
            </div>
            <p class="mt-2 text-sm text-muted">{entry.data.summary}</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted transition-colors group-hover:text-white mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
