---
import { focusAreas } from '../data/focus';
---

<section id="focus" class="section-container">
  <div class="max-w-2xl">
    <p class="section-title">Current Focus</p>
    <h2 class="section-heading">关注方向</h2>
  </div>
  <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {focusAreas.map((area) => (
      <div class="card">
        <h3 class="text-base font-medium">{area.title}</h3>
        <p class="mt-3 text-sm leading-relaxed text-muted">{area.description}</p>
      </div>
    ))}
  </div>
</section>
