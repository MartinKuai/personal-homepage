---
import { focusAreas } from '../data/focus';
---

<section id="focus" class="section-container">
  <div class="max-w-2xl">
    <p class="section-title">TOPICS</p>
    <h2 class="section-heading">Topics</h2>
    <p class="mt-4 text-sm text-muted">
      这些主题会在后续的笔记和项目复盘中反复出现，用来组织我对工具、产品、系统和学习过程的整理。
    </p>
  </div>
  <div class="mt-12 max-w-2xl">
    <div class="space-y-0">
      {focusAreas.map((area) => (
        <a href={area.href} class="group flex items-start justify-between border-b border-white/5 py-5 transition-colors hover:border-white/10">
          <div>
            <h3 class="text-sm font-medium transition-colors group-hover:text-white">{area.title}</h3>
            <p class="mt-1.5 text-sm text-muted">{area.description}</p>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted transition-colors group-hover:text-white mt-0.5 ml-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>
