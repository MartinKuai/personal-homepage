---
interface Props {
  backHref?: string;
}

const { backHref } = Astro.props;
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-dark-900/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
    {backHref ? (
      <a href={backHref} data-back-home-link class="text-sm font-medium text-white transition-colors hover:text-white/80">
        Martin Kuai
      </a>
    ) : (
      <a href="/#top" class="text-sm font-medium text-white transition-colors hover:text-white/80">
        Martin Kuai
      </a>
    )}
    <div class="hidden items-center gap-6 text-sm text-muted md:flex">
      <a href="/#about" class="transition-colors hover:text-white">About</a>
      <a href="/#writing" class="transition-colors hover:text-white">Notes</a>
      <a href="/#focus" class="transition-colors hover:text-white">Topics</a>
      <a href="/#works" class="transition-colors hover:text-white">Builds</a>
      <a href="/#timeline" class="transition-colors hover:text-white">Changes</a>
      <a href="/#contact" class="transition-colors hover:text-white">Contact</a>
    </div>
    <div class="flex items-center gap-5 text-sm text-muted md:hidden">
      <a href="/#writing" class="transition-colors hover:text-white">Notes</a>
      <a href="/#works" class="transition-colors hover:text-white">Builds</a>
      <a href="/#contact" class="transition-colors hover:text-white">Contact</a>
    </div>
  </div>
</nav>

<div class="h-12"></div>

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    // Handle back-home links (Martin Kuai on detail pages)
    const backLink = target.closest("[data-back-home-link]");
    if (backLink instanceof HTMLAnchorElement) {
      try {
        const referrer = document.referrer ? new URL(document.referrer) : null;
        const current = new URL(window.location.href);

        const cameFromHome =
          referrer &&
          referrer.origin === current.origin &&
          referrer.pathname === "/";

        if (cameFromHome && window.history.length > 1) {
          event.preventDefault();
          window.history.back();
          return;
        }
      } catch {
        // fallback: allow normal href navigation
      }
    }

    // Handle section navigation links
    const link = target.closest("a[href^='/#']");
    if (!(link instanceof HTMLAnchorElement)) return;

    const href = link.getAttribute("href");
    if (!href || !href.startsWith("/#")) return;

    const hash = href.slice(1);
    const targetEl = document.querySelector(hash);
    if (!targetEl) return;

    const isHome = window.location.pathname === "/" || window.location.pathname === "";

    event.preventDefault();

    if (isHome) {
      targetEl.scrollIntoView({ behavior: "smooth", block: "start" });
      history.pushState(null, "", href);
    } else {
      window.location.href = href;
    }
  });
</script>
