---
interface Props {
  href: string;
  label?: string;
  sticky?: boolean;
}

const { href, label = "← 返回首页", sticky = false } = Astro.props;
---

{sticky ? (
  <div class="sticky top-12 z-40 border-b border-white/5 bg-dark-900/80 backdrop-blur-md">
    <div class="mx-auto max-w-5xl px-6 py-2">
      <a href={href} data-back-home-link class="inline-block text-xs text-muted transition-colors hover:text-white">
        {label}
      </a>
    </div>
  </div>
) : (
  <a href={href} data-back-home-link class="inline-block text-sm text-muted transition-colors hover:text-white mb-12">
    {label}
  </a>
)}

<script>
  document.addEventListener("click", (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const link = target.closest("[data-back-home-link]");
    if (!(link instanceof HTMLAnchorElement)) return;

    try {
      const referrer = document.referrer ? new URL(document.referrer) : null;
      const current = new URL(window.location.href);

      const cameFromHome =
        referrer &&
        referrer.origin === current.origin &&
        referrer.pathname === "/";

      if (cameFromHome && window.history.length > 1) {
        event.preventDefault();
        window.history.back();
      }
    } catch {
      // fallback: allow normal href navigation
    }
  });
</script>
