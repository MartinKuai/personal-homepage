---
import { profile } from '../data/profile';
---

<section id="works" class="section-container">
  <div class="max-w-2xl">
    <p class="section-title">Featured Works</p>
    <h2 class="section-heading">作品展示</h2>
  </div>
  <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {profile.works.map((work) => (
      <div class="card group cursor-pointer">
        <div class="flex items-center justify-between">
          <h3 class="text-base font-medium">{work.title}</h3>
          <span class="text-xs text-muted">{work.status}</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-muted">{work.description}</p>
        <div class="mt-6 flex items-center gap-2 text-xs text-muted transition-colors group-hover:text-white">
          <span>即将推出</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </div>
    ))}
  </div>
</section>
