---
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
const displayProjects = projects
  .filter((project) => !project.data.draft && !project.data.placeholder)
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return 0;
  });
---

<section id="works" class="section-container">
  <div class="max-w-2xl">
    <p class="section-title">WORKS</p>
    <h2 class="section-heading">Works</h2>
    <p class="mt-4 text-sm text-muted">
      这里会逐步整理一些项目、实验和长期维护的内容。当前版本先保留结构，后续再补充真正值得长期展示的作品。
    </p>
  </div>
  <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {displayProjects.map((project) => (
      <a href={`/projects/${project.slug}`} class="card group block">
        <div class="flex items-center justify-between">
          <h3 class="text-base font-medium">{project.data.title}</h3>
          <span class="text-xs text-muted">{project.data.status}</span>
        </div>
        <p class="mt-3 text-sm leading-relaxed text-muted">{project.data.summary}</p>
        {project.data.stack && project.data.stack.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-1.5">
            {project.data.stack.slice(0, 3).map((tech) => (
              <span class="text-xs px-1.5 py-0.5 rounded bg-white/5 text-muted">{tech}</span>
            ))}
          </div>
        )}
        <div class="mt-6 flex items-center gap-2 text-xs text-muted transition-colors group-hover:text-white">
          <span>查看详情</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </a>
    ))}
  </div>
</section>
