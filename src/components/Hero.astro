---
import { profile } from '../data/profile';
---

<section class="section-container flex min-h-screen flex-col justify-center">
  <div class="flex flex-col gap-12 md:flex-row md:items-center md:gap-16">
    <div class="flex-1">
      <p class="text-sm font-medium tracking-widest text-muted uppercase">
        {profile.tagline.join(' / ')}
      </p>
      <h1 class="mt-8 text-5xl font-light tracking-tight md:text-7xl">
        {profile.name}
      </h1>
      <p class="mt-8 max-w-xl text-lg leading-relaxed text-muted-light">
        {profile.bio}
      </p>
      <div class="mt-12 flex flex-wrap gap-4">
        <a href="#works" class="btn-primary">
          查看项目
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <a href="#contact" class="btn-secondary">
          联系我
        </a>
      </div>
    </div>
    <div class="flex-shrink-0">
      <img
        src="/images/martin-kuai-portrait.png"
        alt="Martin Kuai portrait"
        width="288"
        height="384"
        loading="eager"
        decoding="async"
        class="w-64 rounded-2xl border border-white/10 object-cover md:w-72"
      />
    </div>
  </div>
</section>
