---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackHomeLink from '../../components/BackHomeLink.astro';

export async function getStaticPaths() {
  const entries = await getCollection('timeline');
  return entries
    .filter((entry) => !entry.data.draft && !entry.data.placeholder)
    .map((entry) => ({
      params: { slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { title, summary, period, tags } = entry.data;
const { Content } = await entry.render();
---

<BaseLayout title={`${title} - Martin Kuai`} description={summary}>
  <section class="section-container">
    <div class="max-w-2xl">
      <BackHomeLink href="/#timeline" />

      <article>
        <header class="mb-12">
          <h1 class="text-3xl font-light tracking-tight md:text-4xl">{title}</h1>
          <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-muted">
            {period && <span>{period}</span>}
          </div>
          <p class="mt-4 text-base text-muted-light">{summary}</p>
          {(tags && tags.length > 0) && (
            <div class="mt-4 flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="text-xs text-muted">#{tag}</span>
              ))}
            </div>
          )}
        </header>

        <div class="prose">
          <Content />
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .prose {
    @apply space-y-6 text-base leading-relaxed text-muted-light;
  }
  .prose :global(h2) {
    @apply text-xl font-medium mt-12 mb-4 text-white;
  }
  .prose :global(h3) {
    @apply text-lg font-medium mt-8 mb-3 text-white;
  }
  .prose :global(p) {
    @apply text-base leading-relaxed;
  }
  .prose :global(ul), .prose :global(ol) {
    @apply pl-5 space-y-2;
  }
  .prose :global(li) {
    @apply text-base leading-relaxed;
  }
  .prose :global(code) {
    @apply text-sm bg-white/5 px-1.5 py-0.5 rounded;
  }
  .prose :global(pre) {
    @apply bg-white/5 p-4 rounded-lg overflow-x-auto my-6;
  }
  .prose :global(pre code) {
    @apply bg-transparent p-0;
  }
  .prose :global(blockquote) {
    @apply border-l-2 border-white/20 pl-4 italic text-muted;
  }
  .prose :global(a) {
    @apply text-white underline underline-offset-2 decoration-white/30 hover:decoration-white/60 transition-colors;
  }
  .prose :global(hr) {
    @apply border-white/10 my-8;
  }
</style>
