---
import { topics, getTopicBySlug } from '../../data/topics';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackHomeLink from '../../components/BackHomeLink.astro';

export async function getStaticPaths() {
  return topics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
---

<BaseLayout title={`${topic.title} - Martin Kuai`} description={topic.description}>
  <section class="section-container">
    <div class="max-w-2xl">
      <BackHomeLink href="/#focus" />

      <header class="mb-12">
        <p class="text-sm font-medium tracking-widest text-muted uppercase">FOCUS</p>
        <h1 class="mt-4 text-3xl font-light tracking-tight md:text-4xl">{topic.title}</h1>
        <p class="mt-4 text-base text-muted-light">{topic.description}</p>
      </header>

      <div class="space-y-4">
        {topic.detail.map((line) => (
          <p class="text-sm text-muted leading-relaxed">{line}</p>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
